# 机器人 QQ 号，必须填写，用来判断群消息是否真的 @ 了机器人。
BOT_QQ_ID=
# NapCat OneBot 11 WebSocket 地址，Bot 通过它接收群消息。
NAPCAT_WS_URL=ws://127.0.0.1:3001
# NapCat OneBot 11 HTTP 地址，Bot 通过它发消息和上传文件。
NAPCAT_HTTP_URL=http://127.0.0.1:3000
# NapCat 访问 token；未设置 token 时留空，禁止提交真实值。
NAPCAT_ACCESS_TOKEN=
# NapCat 普通 HTTP 调用超时时间，单位秒。
NAPCAT_HTTP_TIMEOUT_SECONDS=60
# NapCat 文件上传超时时间，单位秒；大 PDF 需要更长时间。
NAPCAT_UPLOAD_TIMEOUT_SECONDS=900
# 单个上传文件最大字节数，超过后会尝试拆分 PDF。
NAPCAT_MAX_UPLOAD_BYTES=104857600
# 上传到 QQ 群文件时文件名最大字节数，过长会自动裁剪。
NAPCAT_MAX_UPLOAD_FILENAME_BYTES=96
# NapCat 上传失败后的重试次数。
NAPCAT_UPLOAD_RETRIES=5

# 群内提示语言，对应 i18n/zh_CN.json。
BOT_LANG=zh_CN
# 自定义 i18n 目录；留空则使用项目内 i18n/。
BOT_I18N_DIR=
# 机器人展示名称，会出现在介绍文案中。
BOT_DISPLAY_NAME=SanBot
# 机器人管理者展示名，会出现在介绍文案中。
BOT_MANAGER_NAME=
# 机器人管理者 QQ，会出现在介绍文案中。
BOT_MANAGER_QQ=
# 机器人管理者 QQ 白名单，多个 QQ 用英文逗号分隔。
BOT_MANAGER_QQ_IDS=
# 全局群白名单，多个群号用英文逗号分隔；留空表示不限制群。
ALLOWED_GROUP_IDS=
# 兼容旧版本的全局群白名单；ALLOWED_GROUP_IDS 为空时才读取。
BOT_ALLOWED_GROUP_IDS=
# 后端健康检查间隔，单位秒；设为 0 可关闭健康监控。
HEALTH_CHECK_INTERVAL_SECONDS=60
# 后端异常或恢复时通知的群号，多个群号用英文逗号分隔；留空使用全局群白名单。
HEALTH_NOTIFY_GROUP_IDS=

# 后端 FastAPI 地址。
BACKEND_URL=http://127.0.0.1:8000
# Bot 调用后端接口的鉴权 token；禁止提交真实值。
BACKEND_API_TOKEN=

# 是否启用 JM 下载功能。
ENABLE_JM_DOWNLOAD=true
# JM 下载功能白名单群，留空表示不额外限制。
JM_DOWNLOAD_ALLOWED_GROUP_IDS=
# 是否启用 JM 搜索功能；优先生效，未设置时兼容 ENABLE_SEARCH。
ENABLE_JM_SEARCH=true
# 旧版 JM 搜索开关，保留用于兼容后端 /api/search。
ENABLE_SEARCH=true
# JM 搜索功能白名单群，留空表示不额外限制。
JM_SEARCH_ALLOWED_GROUP_IDS=
# 是否启用 JM 日榜、周榜、月榜查询。
ENABLE_JM_RANKING=true
# JM 排行榜功能白名单群，留空表示不额外限制。
JM_RANKING_ALLOWED_GROUP_IDS=
# JM 搜索子进程超时时间，单位秒。
SEARCH_TIMEOUT_SECONDS=20
# JM 搜索返回结果数量，最大 10。
SEARCH_RESULT_LIMIT=5
# JM 搜索结果等待用户回复序号的时间，单位秒。
SEARCH_CONFIRM_TIMEOUT_SECONDS=600
# JM 排行榜子进程超时时间，单位秒。
RANKING_TIMEOUT_SECONDS=20
# JM/JavDB 排行榜返回结果数量，最大 20。
RANKING_RESULT_LIMIT=10

# 是否启用 JAV 元数据总开关；关闭后番号查询、AV 搜索、演员搜索、DB 排行榜都会关闭。
ENABLE_JAVLIBRARY=true
# 是否启用番号详情查询，例如 @机器人 JAV SSIS-123。
ENABLE_JAV_QUERY=true
# 番号详情查询白名单群，留空表示不额外限制。
JAV_QUERY_ALLOWED_GROUP_IDS=
# 是否启用 AV 标题搜索，例如 @机器人 AV搜索 标题。
ENABLE_AV_SEARCH=true
# AV 标题搜索白名单群，留空表示不额外限制。
AV_SEARCH_ALLOWED_GROUP_IDS=
# 是否启用演员搜索，例如 @机器人 演员搜索 三上悠亚。
ENABLE_ACTOR_SEARCH=true
# 演员搜索白名单群，留空表示不额外限制。
ACTOR_SEARCH_ALLOWED_GROUP_IDS=
# 是否启用 JavDB 日榜、周榜、月榜查询。
ENABLE_DB_RANKING=true
# JavDB 排行榜白名单群，留空表示不额外限制。
DB_RANKING_ALLOWED_GROUP_IDS=
# 番号数据源单次请求超时时间，单位秒。
JAVLIBRARY_TIMEOUT_SECONDS=8
# 番号查询总超时时间，单位秒。
JAVLIBRARY_TOTAL_TIMEOUT_SECONDS=15
# 番号成功查询缓存时间，单位秒。
JAVLIBRARY_CACHE_TTL_SECONDS=604800
# 番号普通失败缓存时间，单位秒。
JAVLIBRARY_FAILURE_CACHE_TTL_SECONDS=60
# 番号未找到缓存时间，单位秒。
JAVLIBRARY_NOT_FOUND_CACHE_TTL_SECONDS=86400
# 番号源站阻断缓存时间，单位秒。
JAVLIBRARY_BLOCKED_CACHE_TTL_SECONDS=120
# 番号请求超时缓存时间，单位秒。
JAVLIBRARY_TIMEOUT_CACHE_TTL_SECONDS=60
# Javlibrary 基础地址。
JAVLIBRARY_BASE_URL=https://www.javlibrary.com
# Javlibrary 语言路径，常用 cn 或 en。
JAVLIBRARY_LANGUAGE=cn
# 番号数据源尝试顺序，多个源用英文逗号分隔。
JAVLIBRARY_PROVIDER_ORDER=javdb,javlibrary,jav321,javbus
# JavDB 基础地址。
JAVDB_BASE_URL=https://javdb.com
# JavBus 基础地址。
JAVBUS_BASE_URL=https://www.javbus.com
# Jav321 基础地址。
JAV321_BASE_URL=https://www.jav321.com
# 番号抓取模式，可选 curl、http、browser。
JAVLIBRARY_FETCHER=curl
# 番号请求 User-Agent，留空使用内置值。
JAVLIBRARY_USER_AGENT=
# 番号请求 Cookie，禁止提交真实值。
JAVLIBRARY_COOKIE=
# 番号请求代理，留空表示直连。
JAVLIBRARY_PROXY=
# curl-cffi 浏览器指纹，可填 random 或具体指纹。
JAVLIBRARY_IMPERSONATE=random
# 番号临时网络错误重试次数。
JAVLIBRARY_RETRY_TIMES=1
# browser 模式使用的浏览器资料目录。
JAVLIBRARY_BROWSER_PROFILE_DIR=./data/javlibrary-browser
# browser 模式使用的浏览器通道，例如 chrome、msedge；留空使用 Playwright Chromium。
JAVLIBRARY_BROWSER_CHANNEL=
# browser 模式是否无头运行；首次验证建议 false。
JAVLIBRARY_BROWSER_HEADLESS=false
# browser 模式等待手动验证的时间，单位秒。
JAVLIBRARY_BROWSER_WAIT_SECONDS=120
# 演员中文译名别名文件路径。
JAV_ACTOR_ALIAS_PATH=./config/actor-aliases.yml
# 演员搜索是否启用在线别名解析。
JAV_ACTOR_ALIAS_ONLINE=true
# 演员在线别名解析超时时间，单位秒。
JAV_ACTOR_ALIAS_TIMEOUT_SECONDS=4
# 演员搜索最多尝试候选名数量。
JAV_ACTOR_ALIAS_CANDIDATE_LIMIT=6
# 番号查询后等待用户回复资源页、预告片、剧照等动作的时间，单位秒。
JAV_ACTION_TIMEOUT_SECONDS=300

# 是否启用 JavDB 资源页链接入口。
ENABLE_JAV_RESOURCE_PAGE=true
# JavDB 资源页链接白名单群，留空表示不额外限制。
JAV_RESOURCE_PAGE_ALLOWED_GROUP_IDS=
# 是否启用 JavDB 预告片发送。
ENABLE_JAV_TRAILER=true
# JavDB 预告片白名单群，留空表示不额外限制。
JAV_TRAILER_ALLOWED_GROUP_IDS=
# 预告片 m3u8 转 MP4 使用的 ffmpeg 路径。
JAV_TRAILER_FFMPEG_PATH=ffmpeg
# 预告片转 MP4 超时时间，单位秒。
JAV_TRAILER_CONVERT_TIMEOUT_SECONDS=180
# 预告片 MP4 最大字节数。
JAV_TRAILER_MAX_BYTES=104857600
# 预告片请求 Cookie，留空时复用 JAVLIBRARY_COOKIE。
JAV_TRAILER_COOKIE=
# 预告片下载使用的 curl-cffi 浏览器指纹。
JAV_TRAILER_IMPERSONATE=random
# 是否启用剧照预览图发送。
ENABLE_JAV_STILLS=false
# 剧照预览白名单群，留空表示不额外限制。
JAV_STILLS_ALLOWED_GROUP_IDS=
# 每次最多发送的剧照预览图数量。
JAV_STILLS_MAX_COUNT=3
# 剧照入口允许的最大群人数；设为 0 表示不检查人数。
JAV_STILLS_MAX_GROUP_MEMBERS=150
# 是否启用剧照 PDF 打包上传。
ENABLE_JAV_STILLS_PDF=true
# 剧照 PDF 白名单群，留空表示不额外限制。
JAV_STILLS_PDF_ALLOWED_GROUP_IDS=
# 剧照 PDF 最多打包图片数；0 表示不限量。
JAV_STILLS_PDF_MAX_IMAGES=0
# 剧照 PDF 下载并发数，最大 8。
JAV_STILLS_PDF_DOWNLOAD_CONCURRENCY=4
# 剧照图片单次下载超时时间，单位秒。
JAV_STILLS_PDF_DOWNLOAD_TIMEOUT_SECONDS=60
# 单张剧照最大下载字节数。
JAV_STILLS_MAX_IMAGE_BYTES=8388608
# 剧照 PDF 最小图片宽度；低于会跳过，0 表示不检查。
JAV_STILLS_MIN_IMAGE_WIDTH=300
# 剧照 PDF 最小图片高度；低于会跳过，0 表示不检查。
JAV_STILLS_MIN_IMAGE_HEIGHT=200
# 是否启用 MissAV 外部播放链接入口，默认关闭。
ENABLE_MISSAV_LINK=false
# MissAV 外部播放链接基础地址。
MISSAV_BASE_URL=https://missav.live
# MissAV 外部播放链接白名单群；建议必须显式配置。
MISSAV_ALLOWED_GROUP_IDS=
# MissAV 外部播放入口允许的最大群人数；设为 0 表示不检查人数。
MISSAV_MAX_GROUP_MEMBERS=150

# 是否启用 Telegram 频道镜像功能。
ENABLE_TG_MIRROR=false
# Telegram 镜像功能白名单群，留空表示不额外限制。
TG_MIRROR_ALLOWED_GROUP_IDS=
# 是否启用 Telegram 自动拉取；默认关闭，开启后会静默同步新媒体。
ENABLE_TG_AUTO_FETCH=false
# Telegram 自动拉取固定群列表；留空时自动使用后端已绑定 TG 频道的群。
TG_AUTO_FETCH_GROUP_IDS=
# Telegram 自动拉取间隔，单位秒；默认 3600 秒，即 1 小时。
TG_AUTO_FETCH_INTERVAL_SECONDS=3600
# Telegram 自动拉取每个群单次最多发送多少个媒体，最大 10。
TG_AUTO_FETCH_LIMIT=5
# Telegram 镜像模式，telethon 使用用户会话，bot 使用 Bot Token。
TG_MIRROR_MODE=telethon
# Telegram BotFather token，仅 bot 模式需要；禁止提交真实值。
TG_BOT_TOKEN=
# Telegram API ID，仅 telethon 模式需要。
TG_API_ID=
# Telegram API Hash，仅 telethon 模式需要；禁止提交真实值。
TG_API_HASH=
# Telethon 字符串会话；禁止提交真实值。
TG_SESSION_STRING=
# Telethon 本地 session 文件路径。
TG_SESSION_PATH=
# TG 单个图片/视频最大字节数；bot 模式受 Telegram 官方 20MB 限制。
TG_MAX_FILE_BYTES=104857600
# TG 最新默认拉取数量，最大 10。
TG_FETCH_LIMIT=5
# TG 每个频道向前扫描消息数量，最大 100。
TG_SCAN_LIMIT=30
# TG 媒体缓存保留时间，单位秒。
TG_MEDIA_CACHE_TTL_SECONDS=86400

# 是否启用 AstrBot 共存模式；默认关闭，仅在实验分支使用。
ENABLE_ASTRBOT_COEXIST=false
# 交由 AstrBot 处理普通 @ 对话的群号，必须显式填写，多个群号使用英文逗号分隔。
ASTRBOT_COEXIST_GROUP_IDS=

# 是否启用任务历史查询功能。
ENABLE_HISTORY=true
# 任务历史查询白名单群，留空表示不额外限制。
HISTORY_ALLOWED_GROUP_IDS=
# 是否启用管理员运维命令。
ENABLE_ADMIN_COMMANDS=true
# 管理员运维命令白名单群，留空表示不额外限制。
ADMIN_ALLOWED_GROUP_IDS=

# 后端同时运行的下载任务数量。
MAX_CONCURRENT_JOBS=1
# 每个群允许同时存在的活跃任务数，0 表示不限制。
MAX_ACTIVE_JOBS_PER_GROUP=3
# 每个用户允许同时存在的活跃任务数，0 表示不限制。
MAX_ACTIVE_JOBS_PER_USER=1
# 单个下载任务总超时时间，单位秒。
JOB_TIMEOUT_SECONDS=1800
# 下载任务长时间无文件写入时的卡死超时时间，单位秒；0 表示关闭。
JOB_STALL_TIMEOUT_SECONDS=300
# 后端检查下载进度的间隔，单位秒。
JOB_PROGRESS_CHECK_SECONDS=10
# JM 预览获取超时时间，单位秒。
PREVIEW_TIMEOUT_SECONDS=30
# 群内任务进度通知最小间隔，单位秒；0 表示不主动推送进度。
JOB_PROGRESS_NOTIFY_SECONDS=300
# JM 预览后等待用户确认下载的时间，单位秒。
JOB_CONFIRM_TIMEOUT_SECONDS=600
# 普通用户命令冷却时间，单位秒。
USER_COMMAND_COOLDOWN_SECONDS=10
# JM 页数超过该值时需要用户二次确认；0 表示不警告。
LARGE_ALBUM_WARNING_PAGES=100
# JM 页数超过该值时后端自动拒绝；0 表示不限制。
MAX_ALBUM_PAGES=300
# 后端缓存清理间隔，单位秒；0 表示关闭定期清理。
CACHE_CLEANUP_INTERVAL_SECONDS=3600
# 后端任务缓存保留时间，单位秒。
JOB_CACHE_TTL_SECONDS=259200
# Bot 下载/上传临时缓存保留时间，单位秒。
BOT_DOWNLOAD_CACHE_TTL_SECONDS=259200
# JM 预览临时文件缓存保留时间，单位秒。
PREVIEW_CACHE_TTL_SECONDS=86400
# 审计日志保留天数，0 表示不按天数清理。
AUDIT_RETENTION_DAYS=30
# JMComic 图片下载线程数。
JM_DOWNLOAD_IMAGE_THREADS=8
# JMComic 章节下载线程数。
JM_DOWNLOAD_PHOTO_THREADS=2
# JMComic 图片下载线程硬上限。
JM_DOWNLOAD_MAX_IMAGE_THREADS=8
# JMComic 章节下载线程硬上限。
JM_DOWNLOAD_MAX_PHOTO_THREADS=2
# JMComic 配置文件路径，Cookie 等敏感内容写在实际 yml，不提交到 Git。
JMCOMIC_OPTION_PATH=./config/jmcomic-option.yml
# 数据目录路径，保存数据库、缓存和任务文件。
DATA_DIR=./data
