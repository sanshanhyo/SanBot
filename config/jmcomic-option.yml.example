# Copy this file to config/jmcomic-option.yml and fill in your own settings.
# Do not commit cookies, tokens, or login information.

client:
  # api is usually better for servers because the html client may be blocked by IP region.
  impl: api
  retry_times: 5
  postman:
    meta_data:
      headers:
        User-Agent: "Mozilla/5.0"
      cookies:
        # Log in with your browser and copy the AVS cookie for the same JM domain.
        # Do not commit your real cookie.
        AVS: "YOUR_JMCOMIC_AVS_COOKIE_HERE"

download:
  image:
    decode: true
  threading:
    # Increase carefully. Too high may trigger rate limits.
    # You can also override these with JM_DOWNLOAD_IMAGE_THREADS and JM_DOWNLOAD_PHOTO_THREADS.
    image: 20
    photo: 4

dir_rule:
  base_dir: ./data/jmcomic
  rule: Bd_Aid_Pindex
